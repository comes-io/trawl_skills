{
  "name": "@trawlme/skills",
  "version": "0.5.0",
  "description": "Claude Code skills for the Trawl CLI — teaches Claude how to manage scraps via @trawlme/cli",
  "type": "module",
  "bin": {
    "trawlme-skills": "bin/install.js"
  },
  "files": [
    "skills/**/*.md",
    "skills/**/references/**",
    "skills/**/run-local.mjs",
    "skills/**/build-context.mjs",
    "bin/install.js",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "puppeteer-core": "^22.0.0"
  },
  "peerDependenciesMeta": {
    "puppeteer-core": {
      "optional": true
    }
  },
  "scripts": {
    "install-skill": "node bin/install.js",
    "test": "node bin/install.test.mjs && node skills/trawl-scrap-local-test/scripts/run-local.test.mjs && node skills/trawl-scrap-local-test/scripts/build-context.test.mjs"
  },
  "keywords": [
    "trawl",
    "claude",
    "claude-code",
    "skill",
    "scraping",
    "cli"
  ],
  "author": "Pierre Brisorgueil",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/comes-io/trawl_skills.git"
  },
  "homepage": "https://trawl.me",
  "bugs": {
    "url": "https://github.com/comes-io/trawl_skills/issues"
  }
}
